#!/usr/bin/env node
const PptxGenJS = require("pptxgenjs");
const fs = require("fs");
const path = require("path");

const C = {
  navy:"0D2137",darkBlue:"1A3A6B",blue:"2563EB",skyBlue:"3B82F6",lightBlue:"60A5FA",
  accent:"F59E0B",red:"DC2626",green:"16A34A",teal:"0D9488",
  white:"FFFFFF",offWhite:"F8FAFC",gray50:"F1F5F9",gray100:"E2E8F0",gray200:"CBD5E1",
  gray300:"94A3B8",gray500:"64748B",gray700:"334155",gray900:"0F172A",
  text:"1E293B",muted:"64748B",
};
const F = { title:"微软雅黑",body:"微软雅黑"};

function args(){const a=process.argv.slice(2),o={};for(let i=0;i<a.length;i++){if(a[i].startsWith("--")){const k=a[i].slice(2);o[k]=a[i+1]&&!a[i+1].startsWith("--")?a[++i]:true;}}return o;}

function addText(slide,text,x,y,w,h,opts){slide.addText(text,{x,y,w,h,fontFace:F.body,...opts});}
function addTitle(slide,text,x,y,w,h,opts){slide.addText(text,{x,y,w,h,fontFace:F.title,...opts});}

function rRect(slide,x,y,w,h,r,fill,line){
  slide.addShape("roundRect",{x,y,w,h,rectRadius:r/72,fill:{color:fill},line:line||null});
}

// ---- Cover ----
function renderCover(slide,d){
  slide.addShape("rect",{x:0,y:0,w:10,h:5.63,fill:{color:C.navy}});
  slide.addShape("ellipse",{x:6.5,y:-1.5,w:5.5,h:5.5,fill:{color:C.darkBlue}});
  slide.addShape("ellipse",{x:7.2,y:-0.8,w:4,h:4,fill:{color:C.blue,transparency:60}});
  slide.addShape("ellipse",{x:7.8,y:-0.2,w:2.8,h:2.8,fill:{color:C.skyBlue,transparency:70}});
  slide.addShape("rect",{x:0,y:0,w:0.15,h:5.63,fill:{color:C.accent}});
  rRect(slide,0.6,1.3,1.8,0.35,4,C.accent,null);
  addText(slide,"PROFESSIONAL",0.6,1.3,1.8,0.35,{fontSize:9,color:C.navy,bold:true,align:"center",valign:"middle",charSpacing:2});
  addTitle(slide,d.title,0.6,1.85,5.5,1.6,{fontSize:32,color:C.white,bold:true,valign:"top"});
  addText(slide,d.subtitle,0.6,3.5,5.5,0.5,{fontSize:14,color:C.gray300,valign:"top"});
  slide.addShape("rect",{x:0.6,y:4.1,w:2.5,h:0.03,fill:{color:C.accent}});
  addText(slide,(d.date||"2026年3月")+"  |  "+(d.presenter||""),0.6,4.3,5,0.35,{fontSize:11,color:C.gray500});
  addText(slide,d.company||"青岛大数据科技公司",0.6,4.65,5,0.35,{fontSize:11,color:C.gray500,bold:true});
}

// ---- TOC ----
function renderToc(slide,d,n){
  slide.addShape("rect",{x:0,y:0,w:3.2,h:5.63,fill:{color:C.navy}});
  addTitle(slide,"CONTENTS",0.4,0.5,2.8,0.4,{fontSize:11,color:C.gray500,charSpacing:3});
  addTitle(slide,"目录",0.4,0.9,2.8,0.6,{fontSize:28,color:C.white,bold:true});
  slide.addShape("rect",{x:0.4,y:1.6,w:1.2,h:0.04,fill:{color:C.accent}});
  addText(slide,String(n),0.4,5.1,1,0.35,{fontSize:10,color:C.gray500});
  d.items.forEach((item,i)=>{
    const y=0.8+i*0.9;
    slide.addShape("ellipse",{x:3.6,y:y+0.15,w:0.35,h:0.35,fill:{color:i===0?C.blue:C.gray200}});
    addText(slide,String(i+1).padStart(2,"0"),3.6,y+0.15,0.35,0.35,{fontSize:11,color:i===0?C.white:C.gray700,align:"center",valign:"middle",bold:true});
    addText(slide,item,4.15,y+0.08,5.4,0.45,{fontSize:15,color:C.text,valign:"middle"});
    if(i<d.items.length-1) slide.addShape("rect",{x:4.15,y:y+0.65,w:5.3,h:0.01,fill:{color:C.gray100}});
  });
}

// ---- Section ----
function renderSection(slide,d,n){
  slide.addShape("rect",{x:0,y:0,w:10,h:5.63,fill:{color:C.navy}});
  slide.addShape("ellipse",{x:5.5,y:-2,w:7,h:7,fill:{color:C.darkBlue}});
  slide.addShape("ellipse",{x:7,y:-1,w:4.5,h:4.5,fill:{color:C.blue,transparency:50}});
  slide.addShape("rect",{x:0,y:0,w:0.15,h:5.63,fill:{color:C.accent}});
  addTitle(slide,d.title,0.6,1.2,3,1.8,{fontSize:100,color:C.white,bold:true,transparency:20});
  addTitle(slide,d.subtitle,0.6,3.0,5.5,0.8,{fontSize:26,color:C.white,bold:true});
  slide.addShape("rect",{x:0.6,y:3.85,w:2,h:0.04,fill:{color:C.accent}});
  addText(slide,String(n),0.6,5.1,1,0.35,{fontSize:10,color:C.gray500});
}

// ---- Content Left ----
function renderContentLeft(slide,d,n){
  slide.addShape("rect",{x:0,y:0,w:10,h:0.06,fill:{color:C.blue}});
  slide.addShape("rect",{x:0,y:0.06,w:3.5,h:5.57,fill:{color:C.navy}});
  addTitle(slide,d.section||"SECTION",0.4,0.5,2.8,0.35,{fontSize:10,color:C.gray500,charSpacing:2});
  addTitle(slide,d.title,0.4,1.0,2.8,2.5,{fontSize:20,color:C.white,bold:true});
  slide.addShape("ellipse",{x:1.8,y:3.8,w:1.8,h:1.8,fill:{color:C.blue,transparency:70}});
  (d.points||[]).forEach((p,i)=>{
    const y=0.5+i*1.15;
    rRect(slide,3.9,y+0.05,1.3,0.38,4,C.blue,null);
    addText(slide,p.label,3.9,y+0.05,1.3,0.38,{fontSize:10,color:C.white,align:"center",valign:"middle",bold:true});
    addText(slide,p.desc,5.35,y,4.3,0.5,{fontSize:12,color:C.text,valign:"middle"});
  });
  if(d.highlight){
    rRect(slide,3.9,4.75,5.7,0.55,6,{color:C.accent,transparency:90},{color:C.accent,width:1});
    addText(slide,d.highlight,4.05,4.75,5.4,0.55,{fontSize:11,color:C.accent,valign:"middle",bold:true});
  }
  addText(slide,String(n),9.3,5.2,0.5,0.3,{fontSize:9,color:C.gray400,align:"right"});
}

// ---- Four Cards ----
function renderFourCards(slide,d,n){
  slide.addShape("rect",{x:0,y:0,w:10,h:0.06,fill:{color:C.blue}});
  addTitle(slide,d.title,0.5,0.3,9,0.55,{fontSize:20,color:C.text,bold:true});
  if(d.subtitle) addText(slide,d.subtitle,0.5,0.85,9,0.35,{fontSize:12,color:C.muted});
  const items=d.items||[],cardW=4.3,cardH=1.8,gapX=0.4,gapY=0.3;
  const startX=0.5,startY=1.4;
  const pos=[[startX,startY],[startX+cardW+gapX,startY],[startX,startY+cardH+gapY],[startX+cardW+gapX,startY+cardH+gapY]];
  items.forEach((item,i)=>{
    const[x,y]=pos[i];
    rRect(slide,x,y,cardW,cardH,8,C.white,{color:C.gray100,width:0.5});
    slide.addShape("rect",{x,y,w:0.12,h:cardH,fill:{color:item.color||C.blue}});
    const topY=y+0.2;
    slide.addShape("ellipse",{x:x+0.3,y:topY,w:0.4,h:0.4,fill:{color:item.color||C.blue}});
    addText(slide,String(i+1),x+0.3,topY,0.4,0.4,{fontSize:13,color:C.white,align:"center",valign:"middle",bold:true});
    addText(slide,item.name,x+0.8,topY-0.05,cardW-1,0.45,{fontSize:14,color:C.text,bold:true,valign:"middle"});
    slide.addShape("rect",{x:x+0.3,y:topY+0.55,w:cardW-0.5,h:0.015,fill:{color:C.gray100}});
    (item.lines||[]).forEach((line,j)=>{
      addText(slide,"• "+line,x+0.3,topY+0.65+j*0.35,cardW-0.5,0.35,{fontSize:11,color:C.gray700});
    });
  });
  addText(slide,String(n),9.3,5.2,0.5,0.3,{fontSize:9,color:C.gray400,align:"right"});
}

// ---- Timeline ----
function renderTimeline(slide,d,n){
  slide.addShape("rect",{x:0,y:0,w:10,h:0.06,fill:{color:C.blue}});
  addTitle(slide,d.title,0.5,0.3,9,0.55,{fontSize:20,color:C.text,bold:true});
  const steps=d.steps||[],lineY=3.0;
  slide.addShape("rect",{x:1,y:lineY,w:8,h:0.04,fill:{color:C.gray200}});
  steps.forEach((step,i)=>{
    const x=1.3+i*(7.4/Math.max(steps.length-1,1));
    slide.addShape("ellipse",{x:x-0.18,y:lineY-0.14,w:0.36,h:0.36,fill:{color:C.blue}});
    slide.addShape("ellipse",{x:x-0.08,y:lineY-0.04,w:0.16,h:0.16,fill:{color:C.white}});
    addText(slide,step.name,x-0.8,lineY-1.0,1.6,0.7,{fontSize:12,color:C.text,bold:true,align:"center",valign:"bottom"});
    if(step.time) addText(slide,step.time,x-0.8,lineY-1.55,1.6,0.4,{fontSize:10,color:C.muted,align:"center"});
    if(step.desc) addText(slide,step.desc,x-0.8,lineY+0.4,1.6,0.8,{fontSize:10,color:C.gray700,align:"center",valign:"top"});
  });
  addText(slide,String(n),9.3,5.2,0.5,0.3,{fontSize:9,color:C.gray400,align:"right"});
}

// ---- Metrics ----
function renderMetrics(slide,d,n){
  slide.addShape("rect",{x:0,y:0,w:10,h:0.06,fill:{color:C.blue}});
  addTitle(slide,d.title,0.5,0.3,9,0.55,{fontSize:20,color:C.text,bold:true});
  const metrics=d.metrics||[],cardW=2.8,gap=0.3;
  const totalW=metrics.length*cardW+(metrics.length-1)*gap;
  const startX=(10-totalW)/2,startY=1.2;
  metrics.forEach((m,i)=>{
    const x=startX+i*(cardW+gap);
    rRect(slide,x,startY,cardW,2.2,8,C.white,{color:C.gray100,width:0.5});
    slide.addShape("rect",{x:x+0.3,y:startY,w:cardW-0.6,h:0.06,fill:{color:m.color||C.blue}});
    addText(slide,m.value,x,startY+0.3,cardW,0.9,{fontSize:36,color:m.color||C.blue,bold:true,align:"center",valign:"middle"});
    addText(slide,m.label,x+0.2,startY+1.25,cardW-0.4,0.7,{fontSize:12,color:C.text,align:"center",valign:"top"});
  });
  if(d.note) addText(slide,d.note,0.5,3.7,9,0.4,{fontSize:11,color:C.muted,align:"center"});
  addText(slide,String(n),9.3,5.2,0.5,0.3,{fontSize:9,color:C.gray400,align:"right"});
}

// ---- Architecture ----
function renderArch(slide,d,n){
  slide.addShape("rect",{x:0,y:0,w:10,h:0.06,fill:{color:C.blue}});
  addTitle(slide,d.title,0.5,0.3,9,0.55,{fontSize:20,color:C.text,bold:true});
  const layers=d.layers||[],layerH=0.85,startY=1.0,startX=0.5,labelW=1.3,contentW=8.2;
  layers.forEach((layer,i)=>{
    const y=startY+i*layerH,isTop=i===0;
    slide.addShape("rect",{x:startX,y,w:labelW,h:layerH-0.08,fill:{color:isTop?C.blue:C.darkBlue}});
    addText(slide,layer.name,startX,y,labelW,layerH-0.08,{fontSize:12,color:C.white,bold:true,align:"center",valign:"middle"});
    rRect(slide,startX+labelW+0.1,y,contentW,layerH-0.08,4,C.white,{color:C.gray200,width:0.5});
    addText(slide,layer.desc,startX+labelW+0.25,y,contentW-0.2,layerH-0.08,{fontSize:12,color:C.text,valign:"middle"});
  });
  const arrowX=startX+labelW/2;
  for(let i=0;i<layers.length-1;i++){
    const y1=startY+i*layerH+layerH-0.08,y2=startY+(i+1)*layerH;
    slide.addShape("rect",{x:arrowX-0.02,y:y1,w:0.04,h:y2-y1,fill:{color:C.gray300}});
  }
  addText(slide,String(n),9.3,5.2,0.5,0.3,{fontSize:9,color:C.gray400,align:"right"});
}

// ---- Cases Table ----
function renderTable(slide,d,n){
  slide.addShape("rect",{x:0,y:0,w:10,h:0.06,fill:{color:C.blue}});
  addTitle(slide,d.title,0.5,0.3,9,0.55,{fontSize:20,color:C.text,bold:true});
  const cases=d.cases||[],rowH=0.9,startY=1.0,col1=1.8,col2=2.0,col3=5.5;
  slide.addShape("rect",{x:0.5,y:startY,w:9,h:0.45,fill:{color:C.navy}});
  addText(slide,"企业",0.5,startY,col1,0.45,{fontSize:11,color:C.white,bold:true,align:"center",valign:"middle"});
  addText(slide,"模式",0.5+col1,startY,col2,0.45,{fontSize:11,color:C.white,bold:true,align:"center",valign:"middle"});
  addText(slide,"核心做法",0.5+col1+col2,startY,col3,0.45,{fontSize:11,color:C.white,bold:true,align:"center",valign:"middle"});
  cases.forEach((c,i)=>{
    const y=startY+0.45+i*rowH,bg=i%2===0?C.white:C.gray50;
    slide.addShape("rect",{x:0.5,y,w:9,h:rowH,fill:{color:bg},line:{color:C.gray100,width:0.5}});
    addText(slide,c.company,0.6,y,col1-0.1,rowH,{fontSize:12,color:C.text,bold:true,valign:"middle"});
    addText(slide,c.model,0.5+col1,y,col2-0.1,rowH,{fontSize:11,color:C.blue,bold:true,valign:"middle"});
    addText(slide,c.practices.join("、"),0.5+col1+col2,y,col3-0.2,rowH,{fontSize:11,color:C.gray700,valign:"middle"});
  });
  addText(slide,String(n),9.3,5.2,0.5,0.3,{fontSize:9,color:C.gray400,align:"right"});
}

// ---- Three Cols ----
function renderThreeCols(slide,d,n){
  slide.addShape("rect",{x:0,y:0,w:10,h:0.06,fill:{color:C.blue}});
  addTitle(slide,d.title,0.5,0.3,9,0.55,{fontSize:20,color:C.text,bold:true});
  const items=d.items||[],cardW=2.9,gap=0.35;
  const totalW=items.length*cardW+(items.length-1)*gap;
  const startX=(10-totalW)/2,startY=1.1;
  items.forEach((item,i)=>{
    const x=startX+i*(cardW+gap);
    rRect(slide,x,startY,cardW,3.6,8,C.white,{color:C.gray100,width:0.5});
    slide.addShape("rect",{x,y:startY,w:cardW,h:0.9,fill:{color:item.color||C.blue}});
    addText(slide,item.icon||String(i+1),x,startY,cardW,0.9,{fontSize:28,color:C.white,align:"center",valign:"middle",bold:true});
    addText(slide,item.name,x+0.15,startY+1.1,cardW-0.3,0.5,{fontSize:14,color:C.text,bold:true,align:"center"});
    addText(slide,item.desc,x+0.15,startY+1.65,cardW-0.3,1.8,{fontSize:11,color:C.gray700,align:"center"});
  });
  addText(slide,String(n),9.3,5.2,0.5,0.3,{fontSize:9,color:C.gray400,align:"right"});
}

// ---- Ending ----
function renderEnding(slide,d){
  slide.addShape("rect",{x:0,y:0,w:10,h:5.63,fill:{color:C.navy}});
  slide.addShape("ellipse",{x:-2,y:-2,w:6,h:6,fill:{color:C.darkBlue}});
  slide.addShape("ellipse",{x:-1,y:-1,w:4,h:4,fill:{color:C.blue,transparency:60}});
  slide.addShape("ellipse",{x:6,y:2.5,w:5,h:5,fill:{color:C.darkBlue}});
  slide.addShape("ellipse",{x:7,y:3,w:3.5,h:3.5,fill:{color:C.blue,transparency:70}});
  slide.addShape("rect",{x:0,y:0,w:0.15,h:5.63,fill:{color:C.accent}});
  addTitle(slide,d.title,0.6,1.8,6,1,{fontSize:42,color:C.white,bold:true});
  slide.addShape("rect",{x:0.6,y:2.9,w:2,h:0.04,fill:{color:C.accent}});
  addText(slide,d.subtitle,0.6,3.1,6,0.5,{fontSize:15,color:C.gray300});
  addText(slide,d.contact||"青岛大数据科技公司",0.6,4.5,5,0.4,{fontSize:12,color:C.gray500,bold:true});
}

// ---- MAIN ----
const pptx=new PptxGenJS();
pptx.author="青岛大数据科技公司";
pptx.title="国企四体协同管理数字化解决方案";
pptx.subject="数智化穿透监管下的体系构建与实践创新";
pptx.layout="LAYOUT_16x9";

const slides=[];

// 封面
slides.push({type:"cover",title:"国企四体协同管理数字化解决方案",subtitle:"数智化穿透监管下的体系构建与实践创新",date:"2026年3月",presenter:"亮哥",company:"青岛大数据科技公司"});

// 目录
slides.push({type:"toc",items:["政策背景与监管趋势","四体协同管理体系","核心框架与关键工具","实践案例与成效","解决方案与服务内容","合作方式"]});

// 01 政策背景
slides.push({type:"section",title:"01",subtitle:"政策背景与监管趋势"});
slides.push({type:"content_left",section:"POLICY",title:"国资监管进入穿透式监管新时代",points:[
  {label:"2015年",desc:"探索建立一体化管理平台"},
  {label:"2019年",desc:"以风险为导向、内控为核心、合规为重点、法律为保障"},
  {label:"2022年",desc:"《中央企业合规管理办法》要求建立协调运作机制"},
  {label:"2026年",desc:"《穿透式监管指导意见》标志进入体系化落地阶段"},
],highlight:"四全特征：全级次/全链条/全过程/全要素，覆盖投资、财务、采购等十大领域"});
slides.push({type:"content_left",section:"CORE",title:"穿透式监管的本质与目标",points:[
  {label:"本质",desc:"标准穿透而非权力穿透，信息穿透而非决策穿透"},
  {label:"目标",desc:"实现放得活管得住"},
  {label:"全级次",desc:"打破层级壁垒，覆盖集团-子公司-孙公司"},
  {label:"全链条",desc:"覆盖上下游产业链，不留监管死角"},
],highlight:"本质：标准穿透而非权力穿透，信息穿透而非决策穿透"});

// 02 四体协同
slides.push({type:"section",title:"02",subtitle:"四体协同管理体系"});
slides.push({type:"four_cards",title:"四体协同的差异化定位",items:[
  {name:"全面风险管理",color:"2E86AB",lines:["聚焦战略层","风险识别、评估、应对","目标：识大势、防大险"]},
  {name:"内部控制",color:"7C3AED",lines:["聚焦运营层","不相容职责分离、权限指引","目标：建机制、管日常"]},
  {name:"合规管理",color:"059669",lines:["聚焦监管层","外规内化、合规审查","目标：守底线、不越界"]},
  {name:"法务管理",color:"DC2626",lines:["聚焦权益层","合同、案件、知识产权","目标：护权益、防纠纷"]},
]});
slides.push({type:"content_left",section:"SYNERGY",title:"四体协同的核心逻辑",points:[
  {label:"目标统一",desc:"以风险管控为核心，形成有机整体"},
  {label:"流程贯通",desc:"从分散运行向一体化管理转变"},
  {label:"数据共享",desc:"信息互通，打破信息孤岛"},
  {label:"责任共担",desc:"实现1+1+1+1>4的治理效能"},
],highlight:"最终目标：风险可控、合规有序、经营高效"});

// 03 核心框架
slides.push({type:"section",title:"03",subtitle:"核心框架与关键工具"});
slides.push({type:"four_cards",title:"12345风控组织体系",items:[
  {name:"第一责任人",color:C.darkBlue,lines:["董事长/总经理挂帅","承担主体责任"]},
  {name:"两级管控",color:C.blue,lines:["母子公司两级管控","垂直管理穿透"]},
  {name:"三道防线",color:C.skyBlue,lines:["业务部门→合规风险部门","→审计纪检"]},
  {name:"四类人员",color:C.teal,lines:["分管领导、风控负责人","专职人员、兼职人员"]},
]});
slides.push({type:"content_left",section:"TOOLS",title:"三大核心管理工具",points:[
  {label:"风险识别清单",desc:"统一风险描述与分级标准，涵盖战略、财务、运营、合规四大类"},
